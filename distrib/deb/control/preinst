XML_HEADER='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
SNAPSHOT_0_PATH='/opt/eclipse/kura/user/snapshots/snapshot_0.xml'

echo ""
echo "Checking Kura snapshot_0.xml..."

if [[ -f "$SNAPSHOT_0_PATH" ]]; then
  read -r line < "$SNAPSHOT_0_PATH"
  if [[ "$line" != "$XML_HEADER"* ]]; then
    echo "Error: Snapshot encrypted." >&2
    echo "In order to install kura-networking, kura-core must never have been started." >&2
    exit 1
  fi
fi

echo "Kura snapshot_0.xml correct."
